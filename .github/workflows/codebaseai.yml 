name: CodebaseAI CI Analysis

on:
  workflow_run:
    workflows: ["PayFlow API — CI"]
    types: [completed]

jobs:
  analyze:
    if: ${{ github.event.workflow_run.conclusion == 'failure' }}
    runs-on: ubuntu-latest
    steps:
      - name: Send to CodebaseAI
        run: |
          curl -X POST https://api.codebaseai.in/api/webhooks/github \
            -H "Content-Type: application/json" \
            -H "x-codebaseai-key: ${{ secrets.CODEBASEAI_KEY }}" \
            -d "{
              \"action\": \"completed\",
              \"workflow_run\": {
                \"id\": \"${{ github.event.workflow_run.id }}\",
                \"name\": \"${{ github.event.workflow_run.name }}\",
                \"conclusion\": \"${{ github.event.workflow_run.conclusion }}\",
                \"head_sha\": \"${{ github.event.workflow_run.head_sha }}\",
                \"head_branch\": \"${{ github.event.workflow_run.head_branch }}\"
              },
              \"repository\": {
                \"full_name\": \"${{ github.repository }}\",
                \"name\": \"${{ github.event.repository.name }}\",
                \"private\": ${{ github.event.repository.private }},
                \"default_branch\": \"${{ github.event.repository.default_branch }}\",
                \"owner\": { \"login\": \"${{ github.repository_owner }}\" }
              }
            }"